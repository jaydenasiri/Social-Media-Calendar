<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>30-Day Lifestyle Content Calendar</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Epilogue:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --cream: #faf7f2;
    --warm: #f2ece0;
    --blush: #e8c4b8;
    --rose: #c47a6a;
    --terracotta: #a85b47;
    --brown: #3d2218;
    --muted: #8a7060;
    --border: #ddd5c5;

    --cam: #e8c4b8;
    --cam-bg: rgba(196,122,106,0.08);
    --broll: #b8d4c4;
    --broll-bg: rgba(100,160,130,0.08);
    --travel: #c4c8e8;
    --travel-bg: rgba(100,110,180,0.08);
    --beauty: #e8dcc4;
    --beauty-bg: rgba(180,150,90,0.08);
    --food: #c8e4c8;
    --food-bg: rgba(90,160,90,0.08);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--cream);
    color: var(--brown);
    font-family: 'Epilogue', sans-serif;
    min-height: 100vh;
  }

  /* HERO */
  .hero {
    background: var(--brown);
    color: var(--cream);
    padding: 56px 40px 48px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 320px; height: 320px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(232,196,184,0.12) 0%, transparent 70%);
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -40px; left: 30%;
    width: 200px; height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(196,122,106,0.1) 0%, transparent 70%);
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--blush);
    margin-bottom: 16px;
    font-weight: 500;
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.15;
    font-weight: 400;
    margin-bottom: 24px;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--blush);
  }

  .hero-stats {
    display: flex;
    gap: 36px;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 1.9rem;
    color: var(--blush);
    line-height: 1;
  }

  .stat-label {
    font-size: 11px;
    color: rgba(250,247,242,0.5);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* LEGEND */
  .legend {
    background: var(--warm);
    border-bottom: 1px solid var(--border);
    padding: 16px 40px;
  }

  .legend-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    align-items: center;
  }

  .legend-label {
    font-size: 11px;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-right: 4px;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    color: var(--muted);
    cursor: pointer;
    padding: 4px 10px 4px 8px;
    border-radius: 20px;
    border: 1.5px solid transparent;
    transition: all 0.2s;
  }

  .legend-item:hover, .legend-item.active {
    background: white;
    border-color: var(--border);
    color: var(--brown);
  }

  .legend-dot {
    width: 9px; height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* MAIN */
  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 40px 80px;
  }

  /* WEEK SECTIONS */
  .week {
    margin-bottom: 44px;
  }

  .week-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1.5px solid var(--border);
  }

  .week-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 400;
  }

  .week-theme {
    font-size: 12px;
    color: var(--muted);
    font-style: italic;
  }

  .week-tip {
    margin-left: auto;
    font-size: 11px;
    color: var(--rose);
    font-weight: 500;
    background: rgba(196,122,106,0.08);
    padding: 4px 12px;
    border-radius: 20px;
  }

  /* DAY GRID */
  .days-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 10px;
  }

  .day-card {
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 14px 12px;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
  }

  .day-card:hover {
    border-color: var(--rose);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(61,34,24,0.08);
  }

  .day-card.selected {
    border-color: var(--terracotta);
    box-shadow: 0 0 0 3px rgba(168,91,71,0.12);
  }

  .day-num {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--muted);
    margin-bottom: 6px;
  }

  .day-weekday {
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--border);
    margin-bottom: 10px;
  }

  .day-type {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 7px;
    border-radius: 4px;
    margin-bottom: 8px;
  }

  .day-title {
    font-size: 11.5px;
    font-weight: 500;
    color: var(--brown);
    line-height: 1.45;
  }

  /* TYPE COLORS */
  .type-cam { background: var(--cam-bg); color: var(--terracotta); }
  .type-broll { background: var(--broll-bg); color: #4a9070; }
  .type-travel { background: var(--travel-bg); color: #5560b0; }
  .type-beauty { background: var(--beauty-bg); color: #907040; }
  .type-food { background: var(--food-bg); color: #407040; }

  .border-cam { border-top: 3px solid var(--rose); }
  .border-broll { border-top: 3px solid #6daa8e; }
  .border-travel { border-top: 3px solid #7880c8; }
  .border-beauty { border-top: 3px solid #b89050; }
  .border-food { border-top: 3px solid #60a060; }

  /* DETAIL PANEL */
  .detail-panel {
    display: none;
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 16px;
    padding: 28px;
    margin-top: 16px;
    animation: slideDown 0.2s ease;
  }

  .detail-panel.visible {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 28px;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .detail-section h4 {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
    font-weight: 500;
  }

  .detail-section p, .detail-section li {
    font-size: 12.5px;
    color: var(--brown);
    line-height: 1.7;
  }

  .detail-section ul {
    list-style: none;
    padding: 0;
  }

  .detail-section ul li {
    padding: 5px 0;
    border-bottom: 1px solid var(--warm);
    display: flex;
    gap: 8px;
  }

  .detail-section ul li:last-child { border-bottom: none; }

  .detail-section ul li::before {
    content: '—';
    color: var(--blush);
    flex-shrink: 0;
  }

  .hook-box {
    background: var(--warm);
    border-left: 3px solid var(--rose);
    border-radius: 0 8px 8px 0;
    padding: 12px 14px;
    font-size: 12.5px;
    font-style: italic;
    color: var(--brown);
    line-height: 1.6;
  }

  .detail-close {
    position: absolute;
    top: 12px; right: 12px;
    background: none;
    border: none;
    color: var(--muted);
    font-size: 18px;
    cursor: pointer;
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
  }

  .detail-close:hover { background: var(--warm); }

  /* BATCH BANNER */
  .batch-banner {
    background: var(--brown);
    color: var(--cream);
    border-radius: 14px;
    padding: 20px 24px;
    margin-bottom: 40px;
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .batch-banner h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    font-weight: 400;
    margin-bottom: 4px;
  }

  .batch-banner p {
    font-size: 12px;
    color: rgba(250,247,242,0.6);
    line-height: 1.5;
  }

  .batch-items {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-left: auto;
  }

  .batch-item {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    padding: 8px 14px;
    font-size: 11px;
    color: var(--blush);
    text-align: center;
    line-height: 1.4;
  }

  .batch-item strong {
    display: block;
    color: var(--cream);
    font-size: 12px;
  }

  /* FILTER ACTIVE */
  .day-card.filtered-out {
    opacity: 0.2;
    pointer-events: none;
  }

  @media (max-width: 900px) {
    .hero, main, .legend { padding-left: 20px; padding-right: 20px; }
    .days-grid { grid-template-columns: repeat(4, 1fr); }
    .detail-panel.visible { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .days-grid { grid-template-columns: repeat(3, 1fr); }
    .detail-panel.visible { grid-template-columns: 1fr; }
  }
</style>
</head>
