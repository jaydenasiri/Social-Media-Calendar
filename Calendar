      <div class="batch-item"><strong>Tue</strong>2–3 cam<br>videos</div>
      <div class="batch-item"><strong>Thu</strong>2 b-roll<br>videos</div>
      <div class="batch-item"><strong>Sat</strong>1 beauty<br>or food</div>
      <div class="batch-item"><strong>Buffer</strong>Always 3<br>days ahead</div>
    </div>
  </div>

  <div id="calendar"></div>

</main>

