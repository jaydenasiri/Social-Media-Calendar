  { day:30, type:'broll', title:'My 30-day content creation journey — what I learned', hook:'"I posted every day for 30 days. Here\'s the honest debrief."', shots:['Compilation of content creation b-roll','Filming setup shots','Numbers/stats on phone screen','Looking-ahead ending shot'], caption:'Month one: done. Here\'s what actually happened 📊 #contentcreator #30daychallenge', theme:'Week 5: Community & Value' },
];

const weekThemes = [
  { label: 'Week 1', name: 'Introduce Yourself', days: [1,7], tip: '🎯 Hook new followers' },
  { label: 'Week 2', name: 'Travel & Story Time', days: [8,14], tip: '✈️ Your Emirates era' },
  { label: 'Week 3', name: 'Relatable Lifestyle', days: [15,21], tip: '💬 Build connection' },
  { label: 'Week 4', name: 'Go Deeper', days: [22,28], tip: '🔍 Earn trust' },
  { label: 'Week 5', name: 'Community & Value', days: [29,30], tip: '🌱 Build loyalty' },
];

const typeConfig = {
  cam: { label: 'Cam', class: 'type-cam', border: 'border-cam', dot: 'var(--rose)' },
  broll: { label: 'B-Roll', class: 'type-broll', border: 'border-broll', dot: '#6daa8e' },
  travel: { label: 'Travel', class: 'type-travel', border: 'border-travel', dot: '#7880c8' },
  beauty: { label: 'Beauty', class: 'type-beauty', border: 'border-beauty', dot: '#b89050' },
  food: { label: 'Food', class: 'type-food', border: 'border-food', dot: '#60a060' },
};

let selectedDay = null;
let activeFilter = 'all';

function buildCalendar() {
  const cal = document.getElementById('calendar');
  
  weekThemes.forEach(week => {
    const weekVideos = videos.filter(v => v.day >= week.days[0] && v.day <= week.days[1]);
    
    const section = document.createElement('div');
    section.className = 'week';
    section.innerHTML = `
      <div class="week-header">
        <span class="week-title">${week.label} — <em style="font-style:italic;font-family:'Playfair Display',serif;font-weight:400">${week.name}</em></span>
        <span class="week-tip">${week.tip}</span>
      </div>
    `;

    const grid = document.createElement('div');
    grid.className = 'days-grid';

    weekVideos.forEach(v => {
      const tc = typeConfig[v.type];
      const dayOfWeek = DAYS[(v.day - 1) % 7];
      const card = document.createElement('div');
      card.className = `day-card ${tc.border}`;
      card.dataset.day = v.day;
      card.dataset.type = v.type;
      card.innerHTML = `
        <div class="day-num">${v.day}</div>
        <div class="day-weekday">${dayOfWeek}</div>
        <div class="day-type ${tc.class}">${tc.label}</div>
        <div class="day-title">${v.title}</div>
      `;
      card.onclick = () => toggleDetail(v, section, card);
      grid.appendChild(card);
    });

    section.appendChild(grid);

    // Detail panel placeholder
    const panel = document.createElement('div');
    panel.className = 'detail-panel';
    panel.id = `panel-week-${week.days[0]}`;
    section.appendChild(panel);

    cal.appendChild(section);
  });
}

function toggleDetail(v, section, card) {
  const panel = section.querySelector('.detail-panel');
  const allCards = document.querySelectorAll('.day-card');

  if (selectedDay === v.day) {
    panel.classList.remove('visible');
    panel.innerHTML = '';
    card.classList.remove('selected');
    selectedDay = null;
    return;
  }

  // Close all panels
  document.querySelectorAll('.detail-panel').forEach(p => {
    p.classList.remove('visible');
    p.innerHTML = '';
  });
  allCards.forEach(c => c.classList.remove('selected'));

  selectedDay = v.day;
  card.classList.add('selected');

  const tc = typeConfig[v.type];
  panel.innerHTML = `
    <div class="detail-section" style="position:relative">
      <h4>Hook (first 3 seconds)</h4>
      <div class="hook-box">${v.hook}</div>
      <br>
      <h4>Caption</h4>
      <p style="font-size:12px;color:var(--muted);line-height:1.6">${v.caption}</p>
    </div>
    <div class="detail-section">
      <h4>Shot List</h4>
      <ul>${v.shots.map(s => `<li>${s}</li>`).join('')}</ul>
    </div>
    <div class="detail-section">
      <h4>Format</h4>
      <p style="margin-bottom:12px"><span class="day-type ${tc.class}" style="margin:0">${tc.label === 'Cam' ? 'Talking to Camera' : tc.label === 'B-Roll' ? 'B-Roll + Voiceover' : tc.label + ' Content'}</span></p>
      <h4 style="margin-top:16px">Claude Prompt</h4>
      <div class="hook-box" style="font-style:normal;font-size:11.5px">Write a 45-sec TikTok script for my lifestyle account. Topic: "${v.title}". Tone: honest, fun, relatable. Include hook, 3 body points, CTA. I talk to camera and do b-roll voiceover.</div>
    </div>
  `;
  panel.classList.add('visible');
  panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function filterType(type, el) {
  activeFilter = type;
  document.querySelectorAll('.legend-item').forEach(l => l.classList.remove('active'));
  el.classList.add('active');

  document.querySelectorAll('.day-card').forEach(card => {
    if (type === 'all' || card.dataset.type === type) {
      card.classList.remove('filtered-out');
    } else {
      card.classList.add('filtered-out');
    }
  });
}

buildCalendar();
</script>
</body>
</html>
